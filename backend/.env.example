# ===========================================
# Cloud Resume Analyzer — Backend Environment
# ===========================================

# --- Groq AI (required) ---
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.1-8b-instant

# --- AWS (local dev only — Lambda uses IAM role) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- S3 (auto-set in Lambda via serverless.yml) ---
S3_BUCKET_NAME=

# --- DynamoDB (auto-set in Lambda via serverless.yml) ---
DYNAMODB_TABLE_NAME=resumeanalyzer
DYNAMODB_REPORT_KEY=reportId

# --- Cognito Auth ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# --- Server (local dev only) ---
PORT=5001
